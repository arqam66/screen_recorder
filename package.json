{
  "name": "screen-recorder",
  "version": "1.1.0",
  "description": "Screen recorder with face cam overlay, system audio capture, annotation tools, and instant local download",
  "main": "main.js",
  "author": "Arqam",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.screenrecorder",
    "productName": "Screen Recorder",
    "copyright": "Copyright © 2026",
    "files": [
      "index.html",
      "main.js",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Screen Recorder"
    },
    "portable": {
      "artifactName": "Screen-Recorder-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
