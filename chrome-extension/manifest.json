{
  "manifest_version": 3,
  "name": "Screen Recorder",
  "version": "1.0.0",
  "description": "Record screen + camera + voice. Face overlay, laser pointer, instant download. No cloud, no signup.",
  "permissions": [],
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Screen Recorder — Click to open"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
